# Godot editor cache + import artifacts — regenerated on open.
.godot/

# Exports
/android/
*.apk
*.aab

# Sourced art (large/binary) — not repo content
assets/

# Twin models + sidecars (large/binary, delivered by twin-import; loaded at runtime)
/models/
*.glb.import

# Python tooling for import/sim scripts
.venv/

# Framework working files — generated from the xenodot plugin, not repo content
/tools/
/library
/library-twin
# External shared-asset library — symlink to free-library example assets kept outside the game
/x-shared-assets
/transcripts/

# graphify knowledge graph — derived, rebuilt by the graphify CLI + the auto-update hook
/graphify-out/

# Xenodot task board (per-game runtime state)
.xenodot/

# Claude Code per-project runtime data (memory/sessions)
.claude/projects/

# macOS
.DS_Store
