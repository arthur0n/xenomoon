{
  "name": "xenomoon-forge",
  "version": "0.1.9",
  "description": "Xenomoon Forge — POC web UI + agent workflow (triage -> solution -> implement -> verify) you install per project and lock to a Node/web app domain; the orchestrator self-improves per project, with Claude Code",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "node ui/server/cli/setup.js",
    "hermes": "node ui/server/cli/setup.js",
    "hermes:setup": "node ui/server/integrations/hermes/hermes-setup.js",
    "hermes:check": "node ui/server/integrations/hermes/hermes-check.js",
    "codex:setup": "node ui/server/integrations/codex/codex-setup.js",
    "codex:check": "node ui/server/integrations/codex/codex-check.js",
    "kimi:setup": "node ui/server/integrations/kimi/kimi-setup.js",
    "kimi:check": "node ui/server/integrations/kimi/kimi-check.js",
    "new": "node ui/server/cli/new.js",
    "promote": "node ui/server/features/promotions/promote.js",
    "materialize": "node ui/server/cli/materialize.js",
    "doctor": "node ui/server/cli/doctor.js",
    "start": "node ui/server/core/index.js",
    "up": "node ui/server/cli/start-profile.js",
    "badges": "node ui/server/cli/update-badges.js",
    "release": "node ui/server/cli/release-stage.js",
    "token-history": "node ui/server/cli/token-history.js",
    "rebrand": "node scripts/rebrand.mjs",
    "check": "tsc --noEmit",
    "check:structure": "node ui/structure.check.js",
    "check:skills": "node ui/server/cli/gen-skill-scope.js",
    "check:agents": "node ui/server/cli/agents-lint.js",
    "check:agnostic": "bash scripts/check-spine-agnostic.sh",
    "test": "node --test $(find ui -name '*.test.js' -not -path '*/node_modules/*') && node ui/reducer.check.js && node ui/server/features/skills/skills.check.js",
    "test:onboarding": "node ui/server/cli/onboarding.check.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "validate": "npm run check && npm run lint && npm run check:structure && npm run check:skills && npm run check:agents",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.175",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
