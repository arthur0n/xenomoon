{
  "name": "xenodot-forge",
  "version": "0.1.7",
  "description": "Xenodot Forge — POC web UI + agent workflow (design -> implement -> verify) for building Godot-family (Godot / Redot / Blazium) games with Claude Code",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "node ui/server/setup.js",
    "hermes": "node ui/server/setup.js",
    "hermes:setup": "node ui/server/hermes-setup.js",
    "hermes:check": "node ui/server/hermes-check.js",
    "codex:setup": "node ui/server/codex-setup.js",
    "codex:check": "node ui/server/codex-check.js",
    "new": "node ui/server/new.js",
    "promote": "node ui/server/promote.js",
    "materialize": "node ui/server/materialize.js",
    "doctor": "node ui/server/doctor.js",
    "start": "node ui/server/index.js",
    "badges": "node ui/server/update-badges.js",
    "release": "node ui/server/release-stage.js",
    "check": "tsc --noEmit",
    "test": "node ui/reducer.check.js",
    "test:onboarding": "node ui/server/onboarding.check.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "validate": "npm run check && npm run lint",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.175",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
