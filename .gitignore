node_modules/
.DS_Store
logs/
opendocs/
game_assets/

# Your saved game-project path (written by `npm run setup`). Local to each
# fork — the framework is independent of which project it points at.
.xenodot.json

# Optional, vendored-on-demand third-party plugins (e.g. OpenAI's codex-plugin-cc,
# cloned by `npm run codex:setup`). Not part of the framework — never committed.
vendor/

# graphify knowledge graph of the framework itself — derived, rebuilt by the graphify CLI.
graphify-out/

# Detached `npm run start:bg` process records (PID + log per game) — runtime, machine-local.
.xenodot-run/

# Sub-agent handoff documents written under the plugin at runtime — machine-local, not shipped.
plugin/.xenodot/

# Generated visual view of the framework-audit ledger. Source of truth is LEDGER.json; the
# readable LEDGER.md IS committed. Regenerated by `npm run ledger` + the pre-commit hook.
.claude/framework-audits/ledger.html

