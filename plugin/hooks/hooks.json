{
  "description": "Xenodot Forge safety guards — block destructive git/shell operations before they run. (rtk token-proxy is the user's own global hook, not shipped here.)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/block-destructive-git.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/block-destructive-shell.sh\""
          }
        ]
      }
    ]
  }
}
