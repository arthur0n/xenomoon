; Engine configuration file.
; Minimal digital-twin VIEWER scaffolded by `xenodot-forge` (`npm run new -- <twin> --viewer`).
; It is a neutral, runnable shell — no twin model baked in. Models + sidecars arrive
; later under `models/` via twin-import; the DataBus autoload streams live tag values.

config_version=5

[application]

config/name="Xenodot Twin Viewer"
config/description="Minimal digital-twin viewer scaffolded by xenodot-forge. Point it at your model and data source."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

DataBus="*res://core/data_bus.gd"

[debug]

; Strict-mode warnings escalated to errors (the "tsconfig strict" of GDScript).
; Mirrors the godot-code-rules contract; tools/validate.sh fails the build on any
; of these. Keep in sync with the skill's "Warnings reference".
gdscript/warnings/unused_variable=2
gdscript/warnings/unused_local_constant=2
gdscript/warnings/unused_private_class_variable=2
gdscript/warnings/shadowed_variable=2
gdscript/warnings/shadowed_variable_base_class=2
gdscript/warnings/shadowed_global_identifier=2
gdscript/warnings/unreachable_code=2
gdscript/warnings/unreachable_pattern=2
gdscript/warnings/standalone_expression=2
gdscript/warnings/incompatible_ternary=2
gdscript/warnings/untyped_declaration=2
gdscript/warnings/unsafe_property_access=2
gdscript/warnings/unsafe_method_access=2
gdscript/warnings/unsafe_cast=2
gdscript/warnings/unsafe_call_argument=2
gdscript/warnings/assert_always_true=2
gdscript/warnings/assert_always_false=2
gdscript/warnings/integer_division=2
gdscript/warnings/confusable_identifier=2

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[rendering]

renderer/rendering_method="forward_plus"
; Twin scenes (large plant/building models) rely on occlusion culling; enabled at the
; project level so per-scene OccluderInstance3D nodes work the moment they land.
occlusion_culling/use_occlusion_culling=true
