# Secret scan (defense-in-depth). Skips gracefully when gitleaks isn't installed
# locally so it never blocks a contributor who lacks the binary — CI
# (.github/workflows/gitleaks.yml) is the authoritative, always-on gate.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --staged --redact --no-banner
fi

# Interactive release prompt — terminal commits only (skipped for non-TTY such
# as CI or agent commits). Choosing a type bumps package.json and stages a tag
# that post-commit creates. feat → sub-version (v0.1.X); fix|chore|refactor →
# build digit (v0.1.2.X).
if [ -t 1 ]; then
  printf "Release for this commit? [enter=skip] feat|fix|chore|refactor: " >/dev/tty
  read -r XREL </dev/tty || XREL=""
  [ -n "$XREL" ] && node ui/server/cli/release-stage.js "$XREL"
fi

# Keep the README badges in sync with the plugin (the framework's source of truth),
# then lint + format the staged files (lint-staged also tidies the re-staged README).
# update-badges git-adds what it touches so it lands in the commit.
node ui/server/cli/update-badges.js

# Regenerate the audit ledger views from LEDGER.json (source of truth) and stage the readable
# LEDGER.md so it tracks the JSON. ledger.html is gitignored (a generated view, not committed).
node ui/server/cli/gen-ledger.js
git add .claude/framework-audits/LEDGER.md

npx lint-staged

# Enforce the by-domain layout: no loose modules at the top of ui/server or ui/client.
node ui/structure.check.js
