# pre-push: HARD BLOCK any push to a xenodot-forge repo. xenomoon is the DOWNSTREAM fork: it
# FETCHES curated updates FROM xenodot-forge and NEVER pushes to it — neither the source
# (arthur0n/xenodot-forge) nor our GitHub fork-of-the-source (Pexelins/xenodot-forge). Our work is
# published to ONE place: the `xenomoon` remote (arthur0n/xenomoon). See docs/whitelabel/SYNC.md.
remote_name="$1"
remote_url="$2"

case "$remote_url" in
  *xenodot-forge*)
    echo "" >&2
    echo "✖ pre-push BLOCKED — '$remote_url' is a xenodot-forge repo." >&2
    echo "  xenomoon is the downstream fork: it FETCHES from xenodot-forge and NEVER pushes to it." >&2
    echo "  Publish to the 'xenomoon' remote (arthur0n/xenomoon) instead." >&2
    echo "" >&2
    exit 1
    ;;
esac

if [ "$remote_name" = "upstream" ]; then
  echo "✖ pre-push BLOCKED — remote 'upstream' is the forked source (read-only). Never push there." >&2
  exit 1
fi

exit 0
